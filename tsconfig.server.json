{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/server/**/*", "src/backlog/**/*"],
  "exclude": ["node_modules", "dist", "examples", "src/client/**/*", "**/__tests__/**"]
}

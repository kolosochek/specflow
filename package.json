{
  "name": "@dkolosovsky/specflow",
  "version": "0.3.0-alpha",
  "description": "A microframework for spec-driven development. Epic → Milestone → Wave → Slice with strict TDD execution.",
  "type": "module",
  "license": "MIT",
  "author": "Dmitriy Kolosovskiy",
  "homepage": "https://kolosochek.github.io/specflow/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolosochek/specflow.git"
  },
  "bugs": {
    "url": "https://github.com/kolosochek/specflow/issues"
  },
  "keywords": [
    "spec-driven",
    "tdd",
    "agent",
    "backlog",
    "cli",
    "markdown",
    "kanban",
    "trpc"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "specflow": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/backlog",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "ticket": "tsx src/cli.ts",
    "specflow": "tsx src/cli.ts",
    "dev": "concurrently -n srv,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:lib": "tsc -p tsconfig.publish.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "start": "node dist/server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "docs:dev": "vitepress dev docs-site",
    "docs:stats": "tsx scripts/site-stats.ts --write",
    "docs:build": "npm run docs:stats && vitepress build docs-site",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "better-sqlite3": "^11",
    "drizzle-orm": "^0.45",
    "gray-matter": "^4.0.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^6",
    "@mui/material": "^6",
    "@tanstack/react-query": "^5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trpc/client": "^11",
    "@trpc/react-query": "^11",
    "@trpc/server": "^11",
    "@types/better-sqlite3": "^7.6",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9",
    "express": "^5",
    "jsdom": "^29.1.0",
    "node-pty": "^1.1.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "sharp": "^0.34.5",
    "tsx": "^4",
    "typescript": "^5.8",
    "vite": "^6",
    "vitepress": "^1.5.0",
    "vitest": "^4.1.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
